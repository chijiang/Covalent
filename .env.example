# Covalent backend configuration.
# Copy this file to `.env` and edit for your environment:
#   cp .env.example .env
#
# All variables use the AGENT_FRAMEWORK_ prefix and are read by pydantic-settings
# from the process environment or this `.env` file. See README "Configuration"
# and "Authentication" sections for details.

# ---------- Database ----------
# Required for persistent config storage (agents, MCP, sessions, users, audit logs).
AGENT_FRAMEWORK_DATABASE_URL=postgresql+asyncpg://covalent:covalent@localhost:5432/covalent

# ---------- LLM provider (fallbacks; prefer registering in the Service Console) ----------
AGENT_FRAMEWORK_DEFAULT_API_KEY=
AGENT_FRAMEWORK_DEFAULT_BASE_URL=https://api.openai.com/v1
AGENT_FRAMEWORK_DEFAULT_MODEL=gpt-4o-mini
AGENT_FRAMEWORK_DEFAULT_MAX_ITERATIONS=10

# ---------- Skills ----------
AGENT_FRAMEWORK_SKILLS_ROOT_DIR=skills

# ---------- Execution backend ----------
# Where skill code and ad-hoc scripts run. Default "filesystem" runs them as
# local host subprocesses (no isolation). "docker" runs each session's
# skills/scripts inside an isolated per-session container (requires Docker and
# the sandbox image: docker build -t covalent-sandbox:dev -f Dockerfile.sandbox .).
# "kubernetes" (one Pod per session) is planned. See README "Execution Backend".
AGENT_FRAMEWORK_EXECUTION_BACKEND_KIND=filesystem

# --- Docker backend tuning (ignored unless KIND=docker) ---
# AGENT_FRAMEWORK_EXECUTION_BACKEND_DOCKER_IMAGE=covalent-sandbox:dev
# AGENT_FRAMEWORK_EXECUTION_BACKEND_DOCKER_MEM_LIMIT=512m
# AGENT_FRAMEWORK_EXECUTION_BACKEND_DOCKER_PIDS_LIMIT=256
# AGENT_FRAMEWORK_EXECUTION_BACKEND_DOCKER_CPUS=1.0
# Network mode: "none" (default, no outbound — safest, recommended) or "bridge".
# AGENT_FRAMEWORK_EXECUTION_BACKEND_DOCKER_NETWORK=none
# AGENT_FRAMEWORK_EXECUTION_BACKEND_DOCKER_TMPFS_SIZE=128m
# How often (seconds) the reaper reclaims containers whose session was deleted.
# AGENT_FRAMEWORK_EXECUTION_BACKEND_DOCKER_REAPER_INTERVAL_SECONDS=60

# --- Shell tool (sandbox-only; never registered on the filesystem backend) ---
# When enabled AND the backend is docker, agents get a `run_shell` tool that runs
# a shell command inside the session container. It inherits network=none, the
# resource limits, and the ephemeral container — same trust boundary as skill
# code. Off by default. See README "Execution Backend".
# AGENT_FRAMEWORK_EXECUTION_BACKEND_SHELL_TOOL_ENABLED=false
# AGENT_FRAMEWORK_EXECUTION_BACKEND_SHELL_TOOL_BINARY=sh   # or "bash" if the image has it
# AGENT_FRAMEWORK_EXECUTION_BACKEND_SHELL_TOOL_TIMEOUT_SECONDS=120
# AGENT_FRAMEWORK_EXECUTION_BACKEND_SHELL_TOOL_MAX_BYTES=51200

# ---------- Server ports (used by main.py serve and dev.sh) ----------
AGENT_FRAMEWORK_BACKEND_PORT=5170
AGENT_FRAMEWORK_FRONTEND_PORT=3100

# ===========================================================================
# Authentication & Security
# ===========================================================================
# See README "Authentication" for the full model. In short:
#   - /v1/* is the external integration API: authenticated per request with an
#     API token created in the Service Console (Bearer header).
#   - Every other route is gated by a console login (cookie session / JWT /
#     trusted reverse-proxy headers). /healthz and /auth/{login,register,logout}
#     are the only public exceptions.
#   - ONLY mode=dev disables the gate entirely (for local development).

# Console auth mode. One of: dev | local | session | password | trusted_header | jwt
#   dev             -> gate DISABLED; anonymous requests resolve to a local admin.
#                      Use only for local development. NEVER enable in production.
#   local/session/password -> cookie session issued by /auth/login (default).
#   trusted_header  -> trust x-covalent-* headers injected by your reverse proxy.
#   jwt             -> validate an external JWT bearer token.
AGENT_FRAMEWORK_CONSOLE_AUTH_MODE=local

# Secret used to sign console session cookies. CHANGE THIS in any non-dev
# deployment; with the default value anyone can forge a valid session.
AGENT_FRAMEWORK_CONSOLE_SESSION_SECRET=dev-session-secret-change-me

# Pepper mixed into API token hashes. CHANGE THIS in any non-dev deployment.
# Note: rotating this invalidates all existing API tokens.
AGENT_FRAMEWORK_API_TOKEN_HASH_PEPPER=dev-token-pepper-change-me

# ---------- Initial admin (seeded once on first boot) ----------
AGENT_FRAMEWORK_CONSOLE_SEED_ADMIN_ENABLED=true
AGENT_FRAMEWORK_CONSOLE_SEED_ADMIN_USERNAME=admin
AGENT_FRAMEWORK_CONSOLE_SEED_ADMIN_EMAIL=admin@local
AGENT_FRAMEWORK_CONSOLE_SEED_ADMIN_PASSWORD=admin123
AGENT_FRAMEWORK_CONSOLE_SEED_ADMIN_DISPLAY_NAME=Admin
AGENT_FRAMEWORK_CONSOLE_SEED_ADMIN_WORKSPACE_NAME=Default workspace

# Allow self-service sign-up via /auth/register. Disable for closed deployments.
AGENT_FRAMEWORK_CONSOLE_SIGNUP_ENABLED=true

# ---------- JWT mode only (required when CONSOLE_AUTH_MODE=jwt) ----------
# AGENT_FRAMEWORK_CONSOLE_AUTH_JWT_SECRET=
# AGENT_FRAMEWORK_CONSOLE_AUTH_JWT_ISSUER=
# AGENT_FRAMEWORK_CONSOLE_AUTH_JWT_AUDIENCE=
