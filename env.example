# Agent Framework Configuration
# Copy this file to .env and fill in your values.
# All variables need the AGENT_FRAMEWORK_ prefix.

# --- Model Provider ---
# Fallback when no provider is configured in the database (Service Console).
# Prefer registering providers in the console; these env vars apply on first boot
# or when the providers table is empty.
AGENT_FRAMEWORK_DEFAULT_API_KEY=your-api-key
AGENT_FRAMEWORK_DEFAULT_BASE_URL=https://api.openai.com/v1
AGENT_FRAMEWORK_DEFAULT_MODEL=gpt-5-mini

# --- Agent Settings ---
# AGENT_FRAMEWORK_DEFAULT_MAX_ITERATIONS=6
# AGENT_FRAMEWORK_AGENT_SYSTEM_PROMPT=You are a pragmatic assistant.
AGENT_FRAMEWORK_DATABASE_URL=postgresql+asyncpg://<user>:<pass>@localhost:5432/<db_name>

# --- Skills ---
AGENT_FRAMEWORK_SKILLS_ROOT_DIR=skills
# --- Server Ports ---
AGENT_FRAMEWORK_BACKEND_PORT=5170
AGENT_FRAMEWORK_FRONTEND_PORT=3100
AGENT_FRAMEWORK_BACKEND_HOST=127.0.0.1

# --- MCP Servers (optional) ---
# AGENT_FRAMEWORK_MCP_SERVERS_JSON=[{"name":"docs","transport":"streamable_http","url":"http://localhost:8001/mcp"}]

# --- Multi-Agent Config (optional seed data for first boot) ---
AGENT_FRAMEWORK_AGENTS_JSON=[{"name":"default","description":"General-purpose ReAct agent","system_prompt":"You are a general-purpose ReAct assistant. Understand the user's goal, use available tools or delegates only when they improve accuracy or reduce uncertainty, and provide clear, grounded final answers.","reasoning_prompt":"Use a ReAct loop when it helps: understand the task, decide whether the current context is sufficient, use the most relevant tool or delegate only when it reduces uncertainty, incorporate observations, repeat only as needed, and stop once you can answer confidently. Keep the final response clear, direct, and grounded in the evidence you observed.","provider":{"provider":"openai_compatible","model":"qwen3.6-27b","base_url":"https://dashscope.aliyuncs.com/compatible-mode/v1","timeout_seconds":30.0},"skills":[],"local_tools":["get_current_time"],"capabilities":["chat","react","tool_calling","streaming"],"max_iterations":6}]
AGENT_FRAMEWORK_SKILL_SOURCES_JSON=[{"source_type":"git","name":"local-pptx-skill","url":"/path/to/your/local/skill/repo","subdir":"skills/pptx"}]
